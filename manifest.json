{
  "manifest_version": 3,
  "name": "Hangul Fixer",
  "version": "1.1.0",
  "description": "영어로 잘못 입력된 한글을 변환해주는 크롬 확장 프로그램",
  "permissions": ["activeTab", "storage", "clipboardWrite", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "convert_text": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "한영 변환"
    }
  },
  "host_permissions": ["http://*/*", "https://libretranslate.de/"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  }
}
